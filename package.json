{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "lgtm-chrome-extension",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "all": "pnpm build && pnpm check && pnpm lint:fix && pnpm coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@crxjs/vite-plugin": "2.7.0",
    "@types/chrome": "0.2.0",
    "@types/node": "25.9.4",
    "@vitest/coverage-v8": "4.1.9",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-zip-pack": "1.2.4",
    "vitest": "4.1.9"
  }
}
